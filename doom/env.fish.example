# :: Doom Emacs environment configuration for Fish
# ::
# :: IMPORTANT: Since your config.fish is in dotfiles, put real values in a
# :: separate, git-ignored file:
# ::   ~/.config/fish/conf.d/local.fish
# ::
# :: Make sure 'conf.d/local.fish' is in your fish dotfiles .gitignore, then
# :: copy the lines below into it and fill in your real values.

# ─── GitLab integration (gitlab.el) ─────────────────────────────────

# :: GitLab instance URL (use your company's URL if not using gitlab.com)
set -x GITLAB_URL "https://gitlab.com"

# :: Your GitLab project ID (find in project Settings > General)
# :: Can be numeric (e.g., "12345678") or path-based (e.g., "group/project")
set -x GITLAB_PROJECT_ID "YOUR_PROJECT_ID_HERE"

# :: Short name for your project (used in filenames)
# :: Example: "myapp", "backend", "frontend", etc.
set -x GITLAB_PROJECT_NAME "myproject"

# :: Directory where GitLab issue files are stored (created automatically).
# :: Also used by the dashboard's "Saved GitLab Issues" entry.
set -x GITLAB_ISSUES_DIR "$HOME/notes/projects/myproject/issues"

# ─── Projectile (config.el) ─────────────────────────────────────────

# :: Colon-separated list of directories Projectile scans for projects.
# :: Defaults to ~/dev/ when unset.
set -x PROJECT_SEARCH_PATHS "$HOME/dev/"

# ─── API schema navigation (schema.el) ──────────────────────────────

# :: Path to an OpenAPI TypeScript schema (schema.d.ts) for `SPC n e`.
# :: Defaults to ~/notes/schema.d.ts when unset.
set -x SCHEMA_FILE "$HOME/notes/schema.d.ts"

# ─── Optional: switch between multiple GitLab projects ──────────────

